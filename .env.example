NODE_ENV=development
PORT=5000

# PostgreSQL — Supabase / Neon
# Render runs a long-lived process (not serverless), so use Supabase's SESSION pooler
# (port 5432) or a direct connection — NOT the transaction pooler (port 6543), which
# disables prepared statements and isn't meant for persistent connections.
DATABASE_URL=postgresql://user:password@host:5432/silverlink
DATABASE_SSL=true

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend / Brevo via SMTP or Nodemailer)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM="Silver Link <no-reply@silverlink.app>"

# Frontend origin(s) for CORS + Socket.io — comma-separated if you need more than one
# (e.g. local dev + your deployed Vercel URL)
CLIENT_URL=http://localhost:5173,https://silverlink.vercel.app
